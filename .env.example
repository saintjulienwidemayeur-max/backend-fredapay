# ============================================================
# FREDA PAY BACKEND — Variables d'Environnement
# Kopye fichye sa a → .env  epi ranpli TOUT valè yo
# Fè: cp .env.example .env
# ============================================================

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# URL public backend la (ngrok pou dev, domèn reyèl pou prod)
BACKEND_URL=http://localhost:3001

# ── FRONTEND ─────────────────────────────────────────────────
# URL principal Netlify ou localhost pou dev
FRONTEND_URL=http://localhost:5173
# URL 2yèm pou dev (opsyonèl)
FRONTEND_URL_2=

# ── SUPABASE (Requis) ─────────────────────────────────────────
# Dashboard → Settings → API
# URL format: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
# "service_role" secret key (PAS anon key) — pa janm expose frontend
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT (Requis) ──────────────────────────────────────────────
# Min 32 karaktè, random string solid
# Jenere: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANJE_MOI_MIN_32_KARAKTÈ_RANDOM_ICI

# ── MAPLERAD (Requis pou pèman + kat) ────────────────────────
# Dashboard Maplerad → Settings → API Keys
MAPLERAD_PUBLIC_KEY=mpr_pk_VOTRE_CLE_ICI
MAPLERAD_SECRET_KEY=mpr_sk_VOTRE_CLE_ICI
# Webhook secret — Dashboard Maplerad → Webhooks → Secret
MAPLERAD_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# URL webhook Maplerad — antre sa a nan Dashboard Maplerad → Webhooks
MAPLERAD_WEBHOOK_URL=https://backend-fredapay11.onrender.com/api/webhooks/maplerad

# ── DEEPSEEK (Fred'AI) ────────────────────────────────────────
# https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GROQ (Vwa — Whisper STT) ─────────────────────────────────
# https://console.groq.com → API Keys
# Si vid → mod vwa Fred'AI dezaktive
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── BREVO (Emails tranzaksyonèl) ─────────────────────────────
# https://app.brevo.com → Settings → API Keys
# Si vid → emails dezaktive (pa crash)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx

# ── ADMIN ─────────────────────────────────────────────────────
# Token pou rout /api/admin/* — CHANJE pou prod
ADMIN_TOKEN=freda-admin-secret-2026-CHANJE-MOI

# ── KYC — DIDIT (Opsyonèl) ───────────────────────────────────
# https://didit.me → Developer → API Keys
# Si vid → KYC dezaktive
DIDIT_API_KEY=
DIDIT_APP_ID=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
# URL webhook Didit — antre sa a nan Dashboard Didit → Workflow settings
DIDIT_WEBHOOK_URL=https://backend-fredapay11.onrender.com/api/kyc/webhook
DIDIT_BASE_URL=https://verification.didit.me

# ── PAY'M (Mobile Money Haïti — MonCash, NatCash, KashPaw) ──
# Kontakte Pay'm pou credentials
PAYM_CLIENT_ID=
PAYM_CLIENT_SECRET=

# ── LOGO.DEV (Logos marchands sou transaksyon) ───────────────
# https://logo.dev → Dashboard → API Keys
LOGODEV_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LOGODEV_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TAUX HTG (Opsyonèl — default 132.5) ─────────────────────
# Si defini → itilize sa, sinon 132.5 pa defaut
HTG_RATE=132.5

# ── KONT DEMO (App Store / Play Store review) ────────────────
# Imèl kont demo yo, separe pa vigil. Backend la simile TOUT apèl patnè
# pou kont sa yo — zewo vrè lajan, zewo vrè kat.
DEMO_ACCOUNT_EMAILS=demo.review@fredapay.com
DEMO_EMAIL=demo.review@fredapay.com
DEMO_PASSWORD=FredaDemo2026!
DEMO_TAG=demoreview
DEMO_BALANCE_CENTS=100000
